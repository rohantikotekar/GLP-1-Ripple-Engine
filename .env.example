# Copy to .env and fill in. Never commit .env.

# Loop state file location (defaults to ./state.json)
STATE_PATH=state.json

# --- Data feeds (P2) ---
# openFDA works keyless but gets a higher rate limit with a free key.
OPENFDA_API_KEY=
# News source (NewsAPI or leave blank to use RSS)
NEWS_API_KEY=

# --- Sponsors ---
# Nexla pipeline (P2)
NEXLA_PIPELINE_ID=
NEXLA_API_KEY=
# Akash (P3) — deploy target metadata
AKASH_IMAGE_REF=
# Akash-hosted reasoning model wired into the loop's `act` step (P1↔P3).
# Leave AKASH_MODEL_URL blank to run fully deterministic (demo-safe fallback).
# OpenAI-compatible endpoint base, e.g. https://<lease>.akash.network
AKASH_MODEL_URL=
AKASH_MODEL_NAME=llama-3.1-8b-instruct
# Pomerium (P3) — proxy URL the agent's egress is routed through
POMERIUM_PROXY_URL=
