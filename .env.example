# Copy to .env and fill in. Never commit .env.

# Loop state file location (defaults to ./state.json)
STATE_PATH=state.json

# --- Data feeds (P2) — Nexla Express API (required for LIVE sense) ---
# The loop's sense step calls search_feeds via these. Copy from the
# hackathon Nexla org; without them LIVE idles until /inject.
NEXLA_SERVICE_KEY=
NEXLA_API_URL=https://dev-api-express-code.nexla.com/
NEXLA_NEXSET_ID_CLINICALTRIALS=
NEXLA_NEXSET_ID_OPENFDA=
NEXLA_NEXSET_ID_YAHOO=
NEXLA_NEXSET_ID_NEWS=

# Optional direct keys (unused when Nexla is configured)
OPENFDA_API_KEY=
NEWS_API_KEY=

# --- Sponsors ---
# Legacy Nexla pipeline fields (optional; Express API vars above are what matter)
NEXLA_PIPELINE_ID=
NEXLA_API_KEY=
# Akash (P3) — deploy target metadata
AKASH_IMAGE_REF=
# Akash-hosted reasoning model wired into the loop's `act` step (P1↔P3).
# Leave AKASH_MODEL_URL blank to run fully deterministic (demo-safe fallback).
# OpenAI-compatible endpoint base, e.g. https://<lease>.akash.network
AKASH_MODEL_URL=
AKASH_MODEL_NAME=llama-3.1-8b-instruct
# Pomerium (P3) — proxy URL the agent's egress is routed through
POMERIUM_PROXY_URL=
